# Local development environment variables
# Copy to a file named `.env` before running.

DB_HOST=your_aiven_mysql_host
DB_PORT=3306
DB_USER=your_aiven_mysql_user
DB_PASSWORD=your_aiven_mysql_password
DB_NAME=your_aiven_mysql_database

# Set to true if Aiven requires SSL
DB_SSL=true

# Optional: limit concurrent connections
DB_CONNECTION_LIMIT=10

